@model List<FoodOrdering.Domain.Models.CartItem>

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                Shopping Cart
            </h2>
            <p class="text-muted mb-0">
                Review your items before checkout.
            </p>
        </div>
        <a asp-controller="Food"
           asp-action="Index"
           class="btn btn-outline-dark mt-3 mt-md-0">
            Continue Shopping
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5 class="fw-bold mb-2">Your cart is empty</h5>
                <p class="text-muted mb-4">Start adding your favorite meals.</p>
                <a asp-controller="Food"
                   asp-action="Index"
                   class="btn btn-primary">
                    Browse Menu
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">

                        <thead class="table-light">

                            <tr>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Quantity</th>
                                <th>Total</th>
                                <th></th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <img src="@item.ImageUrl"
                                             width="90"
                                             height="70"
                                             style="object-fit:cover;"
                                             class="rounded" />
                                    </td>

                                    <td class="fw-semibold">
                                        @item.Name
                                    </td>

                                    <td>
                                        ₹ @item.Price
                                    </td>

                                    <td>
                                        @item.Quantity
                                    </td>

                                    <td class="fw-semibold">
                                        ₹ @(item.Price * item.Quantity)
                                    </td>

                                    <td class="text-end">

                                        <a asp-action="Remove"
                                           asp-route-id="@item.FoodItemId"
                                           class="btn btn-outline-danger btn-sm">
                                            Remove
                                        </a>

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>
            </div>
        </div>

        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mt-4">
            <h4 class="fw-bold text-primary mb-3 mb-md-0">
                Grand Total: ₹ @Model.Sum(x => x.Price * x.Quantity)
            </h4>

            <a asp-action="Checkout"
               class="btn btn-success btn-lg">
                Checkout
            </a>
        </div>
    }

</div>
