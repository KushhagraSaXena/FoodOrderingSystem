@model FoodOrdering.Domain.Entities.Order

<div class="container py-5">

    <div class="text-center mb-5">

        <div class="mb-4">

            <span class="badge bg-success fs-6 mb-3">Order Confirmed</span>

            <h1 class="text-success fw-bold">
                Order Placed Successfully
            </h1>

            <p class="text-muted fs-5">
                Thank you for your order. Your items are being prepared.
            </p>

        </div>

        <div class="alert alert-success d-inline-block px-4">

            <strong>
                Order ID:
            </strong>

            #@Model.Id

        </div>

    </div>

    <div class="card shadow-sm border-0">

        <div class="card-header bg-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">
                Order Summary
            </h4>

            <span class="text-muted">@Model.OrderDate.ToString("dd MMM yyyy")</span>

        </div>

        <div class="card-body">

            <div class="table-responsive">
                <table class="table align-middle">

                    <thead class="table-light">

                        <tr>

                            <th>Image</th>
                            <th>Food</th>
                            <th>Qty</th>
                            <th>Price</th>

                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>

                                <td>

                                    <img src="@item.FoodItem?.ImageUrl"
                                         width="70"
                                         height="70"
                                         style="object-fit:cover;
                                                border-radius:10px;" />

                                </td>

                                <td>
                                    @item.FoodItem?.Name
                                </td>

                                <td>
                                    @item.Quantity
                                </td>

                                <td>
                                    ₹ @item.Price
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>
            </div>

            <div class="text-end mt-4">

                <h4 class="fw-bold text-primary">

                    Total:
                    ₹ @Model.TotalAmount

                </h4>

            </div>

        </div>

    </div>

    <div class="text-center mt-4">

        <a asp-controller="Orders"
           asp-action="Invoice"
           asp-route-id="@Model.Id"
           class="btn btn-dark btn-lg me-2">

            Download Invoice

        </a>

        <a asp-controller="Food"
           asp-action="Index"
           class="btn btn-primary btn-lg me-2">

            Continue Shopping

        </a>

        <a asp-controller="Orders"
           asp-action="Index"
           class="btn btn-outline-dark btn-lg">

            View Orders

        </a>

    </div>

</div>
