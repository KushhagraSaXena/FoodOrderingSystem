<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FoodOrdering.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FoodOrdering.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-4">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Food" asp-action="Index">
                    FoodOrdering.Web
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarContent">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">

                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Home"
                               asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Food"
                               asp-action="Index">
                                Food Menu
                            </a>
                        </li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark"
                                   asp-area="Admin"
                                   asp-controller="Orders"
                                   asp-action="Index">
                                    Admin Orders
                                </a>
                            </li>
                        }
                    </ul>

                    <ul class="navbar-nav align-items-center">

                        <li class="nav-item me-3">
                            <button class="btn btn-outline-secondary btn-sm theme-toggle"
                                    type="button"
                                    data-theme-toggle
                                    aria-label="Toggle theme">
                                <span class="theme-toggle-text">Light</span>
                            </button>
                        </li>

                        <li class="nav-item me-3">
                            <a class="nav-link"
                               asp-controller="Cart"
                               asp-action="Index">
                                🛒 Cart
                            </a>
                        </li>

                        <partial name="_LoginPartial" />

                        <li class="nav-item">
                            <a class="nav-link text-dark"
                               asp-controller="Orders"
                               asp-action="Index">
                                Orders
                            </a>
                        </li>

                    </ul>

                </div>
            </div>
        </nav>
    </header>
    <div class="container pb-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FoodOrdering.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
