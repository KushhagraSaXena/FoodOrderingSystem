@model IEnumerable<FoodOrdering.Domain.Entities.Order>

<div class="container py-4">

    <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold mb-1">
                My Orders
            </h2>
            <p class="text-muted mb-0">
                Track your recent purchases and totals.
            </p>
        </div>
        <a asp-controller="Food"
           asp-action="Index"
           class="btn btn-outline-dark mt-3 mt-md-0">
            Browse Menu
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <h5 class="fw-bold mb-2">No orders yet</h5>
                <p class="text-muted mb-4">Place an order to see it here.</p>
                <a asp-controller="Food"
                   asp-action="Index"
                   class="btn btn-primary">
                    Start Ordering
                </a>
            </div>
        </div>
    }

    @foreach (var order in Model)
    {
        <div class="card shadow-sm border-0 mb-4">

            <div class="card-header bg-white d-flex flex-column flex-md-row justify-content-between align-items-md-center">

                <div>
                    <div class="fw-semibold">Order #@order.Id</div>
                    <small class="text-muted">@order.OrderDate</small>
                </div>

                <span class="badge bg-success fs-6 mt-3 mt-md-0">
                    @order.Status
                </span>

            </div>

            <div class="card-body">

                <div class="table-responsive">
                    <table class="table align-middle">

                        <thead class="table-light">

                            <tr>
                                <th>Food</th>
                                <th>Quantity</th>
                                <th>Price</th>
                            </tr>

                        </thead>

                        <tbody>

                            @foreach (var item in order.OrderItems)
                            {
                                <tr>

                                    <td>
                                        @item.FoodItem?.Name
                                    </td>

                                    <td>
                                        @item.Quantity
                                    </td>

                                    <td>
                                        ₹ @item.Price
                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>
                </div>

                <div class="text-end">

                    <div class="d-flex flex-column flex-md-row justify-content-end align-items-md-center gap-2">
                        <h5 class="fw-bold text-primary mb-0">
                            Total: ₹ @order.TotalAmount
                        </h5>
                        <a asp-controller="Orders"
                           asp-action="Invoice"
                           asp-route-id="@order.Id"
                           class="btn btn-outline-dark btn-sm">
                            Download Invoice
                        </a>
                    </div>

                </div>

            </div>

        </div>
    }

</div>
