@{
    ViewData["Title"] = "Home";
}

<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-6">
                <span class="badge bg-warning text-dark mb-3">
                    Fresh, Fast, Delicious
                </span>
                <h1 class="display-5 fw-bold">
                    Order your favorites
                    in minutes.
                </h1>
                <p class="lead text-muted">
                    Discover curated meals, snacks, and drinks made for every craving.
                    Quick checkout, fast delivery, and unbeatable taste.
                </p>
                <div class="d-flex gap-2">
                    <a asp-controller="Food"
                       asp-action="Index"
                       class="btn btn-primary btn-lg">
                        Browse Menu
                    </a>
                    <a asp-controller="Cart"
                       asp-action="Index"
                       class="btn btn-outline-dark btn-lg">
                        View Cart
                    </a>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="p-4 bg-light rounded-4 shadow-sm">
                    <h4 class="fw-bold mb-3">
                        Why FoodOrdering?
                    </h4>
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">🍕 Curated menu with fresh ingredients</li>
                        <li class="mb-2">⚡ Lightning-fast checkout experience</li>
                        <li class="mb-2">🎉 Deals and combos every day</li>
                        <li>📦 Real-time order tracking</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="fw-bold">Handpicked Meals</h5>
                        <p class="text-muted mb-0">
                            Taste chef-selected dishes designed for your cravings.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="fw-bold">Quick Delivery</h5>
                        <p class="text-muted mb-0">
                            Stay hungry less. We deliver fast and fresh.
                        </p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="fw-bold">Secure Payments</h5>
                        <p class="text-muted mb-0">
                            Pay confidently with safe and reliable checkout.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
